DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/document_intelligence
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=document-intelligence
S3_REGION=us-east-1
SCHEMA_REGISTRY_DIR=schemas
API_KEY=dev-local-api-key

# Required by the worker's real AnthropicModelProvider (docker-compose.yml)
# and by `uv run arq document_intelligence.worker.WorkerSettings` locally.
ANTHROPIC_API_KEY=
